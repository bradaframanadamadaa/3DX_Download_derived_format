<Window x:Class="DerivedOutputDownloader3DX.UI.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Téléchargement en cours…"
        Width="580" Height="400"
        MinWidth="480" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#005386" Padding="20,0">
            <Grid>
                <TextBlock Text="Téléchargement des formats dérivés"
                           Foreground="White" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ProgressText}"
                           Foreground="#A8CFEA" FontFamily="Segoe UI" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Contenu -->
        <Grid Grid.Row="1" Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barre de progression globale -->
            <ProgressBar Grid.Row="0"
                         Minimum="0" Maximum="{Binding TotalCount, Mode=OneWay}"
                         Value="{Binding DoneCount, Mode=OneWay}"
                         Height="8" Foreground="#005386" Background="#DDE3EA" BorderThickness="0"/>

            <!-- Liste des fichiers -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Jobs}"
                      BorderThickness="1" BorderBrush="#DDE3EA"
                      FontFamily="Segoe UI" FontSize="12"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Icône" Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusIcon}" FontSize="14" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Format" DisplayMemberBinding="{Binding Format}" Width="70"/>
                        <GridViewColumn Header="Fichier" DisplayMemberBinding="{Binding FileName}" Width="180"/>
                        <GridViewColumn Header="Statut" DisplayMemberBinding="{Binding StatusText}" Width="240"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- Boutons -->
        <Border Grid.Row="2" Background="#EEF1F5" BorderBrush="#DDE3EA" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📂  Ouvrir le dossier"
                        Command="{Binding OpenFolderCommand}"
                        IsEnabled="{Binding IsCompleted}"
                        Margin="0,0,12,0"
                        Padding="14,6"
                        FontFamily="Segoe UI" FontSize="12"
                        Background="White" BorderBrush="#005386" BorderThickness="1"
                        Foreground="#005386" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="#005386"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="BorderBrush" Value="#B0BEC5"/>
                                                <Setter Property="Foreground" Value="#B0BEC5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8F4FD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Fermer"
                        Click="CloseButton_Click"
                        Padding="14,6"
                        FontFamily="Segoe UI" FontSize="12"
                        Background="#005386" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#005386"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#006DB7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
